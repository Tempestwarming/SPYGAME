<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Find The Spy</title>
    <style>
        :root {
            --red-glow: rgba(255, 0, 0, 0.6);
            --dark-bg: #0a0a0a;
        }

        body, html {
            margin: 0; padding: 0; height: 100%;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--dark-bg);
            color: white;
            overflow: hidden;
            user-select: none;
        }

        .screen {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            width: 100vw;
            background-size: cover;
            background-position: center;
            text-align: center;
        }

        .active { display: flex; }

        /* Backgrounds */
        #menu-screen { background-image: linear-gradient(to bottom, rgba(0,0,0,0.7), var(--dark-bg)), url('assets/main_spy.png'); }
        #setup-screen { background: radial-gradient(circle at center, #2b0000 0%, #0a0a0a 100%); }
        #reveal-screen { background-image: linear-gradient(to bottom, rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('assets/pointing_shadows.png'); }

        h1 { font-size: 3rem; text-shadow: 0 0 20px var(--red-glow); margin-bottom: 2rem; letter-spacing: 2px; }

        .btn {
            background: #222;
            border: 2px solid #444;
            color: white;
            padding: 15px 40px;
            margin: 10px;
            border-radius: 50px;
            font-size: 1.2rem;
            width: 250px;
            transition: 0.3s;
            cursor: pointer;
        }

        .btn:active { background: #400; border-color: red; box-shadow: 0 0 15px red; }

        /* Sliders */
        .setup-group { width: 80%; margin: 15px 0; text-align: left; }
        .setup-group label { display: block; margin-bottom: 5px; color: #ccc; font-size: 0.9rem; }
        input[type=range] { width: 100%; accent-color: red; }

        /* Reveal Swipe Logic */
        #swipe-zone {
            width: 100%; height: 60vh;
            display: flex; flex-direction: column;
            justify-content: center; align-items: center;
            position: relative;
        }

        #secret-box {
            font-size: 2rem;
            font-weight: bold;
            color: white;
            background: rgba(255, 0, 0, 0.2);
            padding: 20px;
            border-radius: 15px;
            border: 1px solid red;
            opacity: 0;
            transform: translateY(50px);
            transition: 0.3s ease-out;
        }

        .swiped-up #secret-box { opacity: 1; transform: translateY(0); }

        #timer-display { font-size: 5rem; font-weight: bold; color: white; text-shadow: 0 0 20px red; }
    </style>
</head>
<body>

    <div id="menu-screen" class="screen active">
        <h1>FIND THE SPY</h1>
        <button class="btn" onclick="showScreen('setup-screen')">NEW GAME</button>
        <button class="btn" onclick="alert('Pass the phone to see your role. Find the spy before time runs out!')">HOW TO PLAY</button>
        <button class="btn" id="sound-btn" onclick="toggleSound()">SOUND: ON</button>
    </div>

    <div id="setup-screen" class="screen">
        <h2>GAME SETUP</h2>
        <div class="setup-group">
            <label>Players: <span id="p-val">5</span></label>
            <input type="range" min="3" max="20" value="5" id="players" oninput="updateVal('p-val', this.value)">
        </div>
        <div class="setup-group">
            <label>Spies: <span id="s-val">1</span></label>
            <input type="range" min="1" max="7" value="1" id="spies" oninput="updateVal('s-val', this.value)">
        </div>
        <div class="setup-group">
            <label>Duration: <span id="d-val">5</span> min</label>
            <input type="range" min="1" max="15" value="5" id="duration" oninput="updateVal('d-val', this.value)">
        </div>
        <div class="setup-group">
            <label>Category</label>
            <select id="category" class="btn" style="width:100%; height:auto;">
                <option value="places.csv">Places</option>
                <option value="jobs.csv">Jobs</option>
                <option value="events.csv">Events</option>
            </select>
        </div>
        <button class="btn" style="background:red;" onclick="startGame()">START GAME</button>
    </div>

    <div id="reveal-screen" class="screen">
        <h2 id="player-title">PLAYER 1</h2>
        <div id="swipe-zone" ontouchstart="handleSwipe(true)" ontouchend="handleSwipe(false)" onmousedown="handleSwipe(true)" onmouseup="handleSwipe(false)">
            <p id="swipe-prompt">↑ SWIPE UP TO REVEAL ↑</p>
            <div id="secret-box">SECRET WORD</div>
        </div>
        <button id="next-btn" class="btn" style="display:none;" onclick="nextPlayer()">NEXT PLAYER</button>
    </div>

    <div id="game-screen" class="screen">
        <div id="timer-display">05:00</div>
        <button id="start-timer-btn" class="btn" onclick="runTimer()">PRESS TO START</button>
        <button id="reveal-spy-btn" class="btn" style="display:none; background:red;" onclick="revealWinner()">REVEAL THE SPY</button>
    </div>

    <script>
        let gameState = {
            totalPlayers: 0,
            spyCount: 0,
            spies: [],
            currentPlayer: 1,
            secretWord: "",
            time: 300,
            sound: true
        };

        function showScreen(id) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        function updateVal(id, val) { document.getElementById(id).innerText = val; }

        function toggleSound() {
            gameState.sound = !gameState.sound;
            document.getElementById('sound-btn').innerText = `SOUND: ${gameState.sound ? 'ON' : 'OFF'}`;
        }

        async function startGame() {
            gameState.totalPlayers = parseInt(document.getElementById('players').value);
            gameState.spyCount = parseInt(document.getElementById('spies').value);
            gameState.time = parseInt(document.getElementById('duration').value) * 60;
            gameState.currentPlayer = 1;
            gameState.spies = [];

            // Pick Spies
            while(gameState.spies.length < gameState.spyCount) {
                let r = Math.floor(Math.random() * gameState.totalPlayers) + 1;
                if(!gameState.spies.includes(r)) gameState.spies.push(r);
            }

            // Fetch Word
            const cat = document.getElementById('category').value;
            try {
                const res = await fetch(`topics/${cat}`);
                const text = await res.text();
                const words = text.split('\n').filter(w => w.trim() !== "");
                gameState.secretWord = words[Math.floor(Math.random() * words.length)];
            } catch (e) {
                gameState.secretWord = "SUBMARINE (Sample)"; // Fallback
            }

            setupReveal();
            showScreen('reveal-screen');
        }

        function handleSwipe(isHolding) {
            const screen = document.getElementById('reveal-screen');
            if(isHolding) {
                screen.classList.add('swiped-up');
                document.getElementById('next-btn').style.display = 'block';
            } else {
                screen.classList.remove('swiped-up');
            }
        }

        function setupReveal() {
            document.getElementById('player-title').innerText = `PLAYER ${gameState.currentPlayer}`;
            const isSpy = gameState.spies.includes(gameState.currentPlayer);
            document.getElementById('secret-box').innerText = isSpy ? "YOU ARE THE SPY" : `WORD: ${gameState.secretWord}`;
            document.getElementById('next-btn').style.display = 'none';
        }

        function nextPlayer() {
            if(gameState.currentPlayer < gameState.totalPlayers) {
                gameState.currentPlayer++;
                setupReveal();
            } else {
                showScreen('game-screen');
                updateTimerDisplay();
            }
        }

        function updateTimerDisplay() {
            let m = Math.floor(gameState.time / 60);
            let s = gameState.time % 60;
            document.getElementById('timer-display').innerText = `${m}:${s < 10 ? '0'+s : s}`;
        }

        function runTimer() {
            document.getElementById('start-timer-btn').style.display = 'none';
            let interval = setInterval(() => {
                gameState.time--;
                updateTimerDisplay();
                if(gameState.time <= 0) {
                    clearInterval(interval);
                    document.getElementById('timer-display').innerText = "TIME'S UP!";
                    document.getElementById('reveal-spy-btn').style.display = 'block';
                }
            }, 1000);
        }

        function revealWinner() {
            alert(`The Spies were Player(s): ${gameState.spies.join(', ')}`);
            location.reload();
        }
    </script>
</body>
</html>
